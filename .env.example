# ─────────────────────────────────────────────
# Multi-Agente de Vagas — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env no repositório
# ─────────────────────────────────────────────

# Anthropic (obrigatório)
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase (backend Python — use SERVICE ROLE KEY) ──
# Encontre em: Supabase Dashboard → Settings → API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=eyJhbGci...service_role_key

# Adzuna Brasil — vagas PT-BR (chave gratuita em developer.adzuna.com)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Jooble Brasil — vagas PT-BR (chave gratuita em jooble.org/api/about)
JOOBLE_API_KEY=

# Google APIs (opcional — para Gmail, Sheets e Calendar)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_SHEET_ID=
EMAIL_REMETENTE=seu@email.com

# LinkedIn (opcional — para scraping autenticado)
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
